#!/bin/bash
# EspoCRM Database Backup Script
set -euo pipefail

TIMESTAMP=$(date +%Y%m%d_%H%M%S)
BACKUP_DIR="/opt/backup/database"
RETENTION_DAYS={{ backup_retention_days }}
DB_CONTAINER="{{ espocrm_db_container | default('espocrm-db') }}"
DB_NAME="{{ espocrm_db_name }}"
DB_USER="{{ espocrm_db_user }}"
DB_PASSWORD="${MYSQL_ROOT_PASSWORD:?MYSQL_ROOT_PASSWORD not set}"

mkdir -p "$BACKUP_DIR"

docker exec "$DB_CONTAINER" \
  mariadb-dump -u"$DB_USER" -p"$DB_PASSWORD" \
  --single-transaction --routines --triggers --events \
  "$DB_NAME" | gzip > "$BACKUP_DIR/espocrm_${TIMESTAMP}.sql.gz"

find "$BACKUP_DIR" -name "espocrm_*.sql.gz" -mtime +"$RETENTION_DAYS" -delete

SIZE=$(du -h "$BACKUP_DIR/espocrm_${TIMESTAMP}.sql.gz" | cut -f1)
COUNT=$(ls -1 "$BACKUP_DIR" | wc -l)

echo "[$(date)] Backup: espocrm_${TIMESTAMP}.sql.gz ($SIZE), $COUNT files total"

WEBHOOK="{{ discord_webhook | default('') }}"
if [ -n "$WEBHOOK" ]; then
  curl -s -X POST "$WEBHOOK" -H "Content-Type: application/json" -d "{
    \"embeds\": [{
      \"title\": \"Database Backup Complete\",
      \"color\": 65280,
      \"fields\": [
        {\"name\":\"File\",\"value\":\"espocrm_${TIMESTAMP}.sql.gz\"},
        {\"name\":\"Size\",\"value\":\"$SIZE\",\"inline\":true},
        {\"name\":\"Retention\",\"value\":\"$COUNT files (${RETENTION_DAYS}d)\",\"inline\":true}
      ],
      \"timestamp\": \"$(date -u +%Y-%m-%dT%H:%M:%SZ)\"
    }]
  }"
fi
