#!/bin/bash
# Daily health check — runs daily at 8:00 AM UTC
# Posts container status, disk, memory to Discord if webhook is set

WEBHOOK="{{ discord_webhook | default('') }}"
[ -z "$WEBHOOK" ] && exit 0

UPTIME=$(uptime -p)
DISK=$(df -h / | awk 'NR==2{print $3"/"$2" ("$5")"}')
MEMORY=$(free -h | awk 'NR==2{print $3"/"$2"}')
BACKUP_COUNT=$(ls /opt/backup/database/*.gz 2>/dev/null | wc -l)

UNHEALTHY=$(docker ps --filter "health=unhealthy" --format "table {% raw %}{{.Names}}{% endraw %}" | tail -n +2 | tr '\n' ' ')
RESTARTING=$(docker ps --filter "status=restarting" --format "table {% raw %}{{.Names}}{% endraw %}" | tail -n +2 | tr '\n' ' ')
CERTS=$(python3 -c "
import json
d=json.load(open('/opt/traefik/letsencrypt/acme.json'))
print(', '.join(c['domain']['main'] for c in d['letsencrypt']['Certificates']))
" 2>/dev/null)

if [ -n "$UNHEALTHY$RESTARTING" ]; then
  COLOR=16711680
  TITLE="Health Alert - Issues Detected"
else
  COLOR=65280
  TITLE="Daily Health - All Systems Normal"
fi

FIELDS=""
FIELDS="${FIELDS}{\"name\":\"Uptime\",\"value\":\"$UPTIME\",\"inline\":true},"
FIELDS="${FIELDS}{\"name\":\"Disk\",\"value\":\"$DISK\",\"inline\":true},"
FIELDS="${FIELDS}{\"name\":\"Memory\",\"value\":\"$MEMORY\",\"inline\":true},"
FIELDS="${FIELDS}{\"name\":\"Backups\",\"value\":\"$BACKUP_COUNT files\",\"inline\":true},"
FIELDS="${FIELDS}{\"name\":\"SSL Certs\",\"value\":\"$CERTS\",\"inline\":false},"

[ -n "$UNHEALTHY" ] && FIELDS="${FIELDS}{\"name\":\"Unhealthy\",\"value\":\"$UNHEALTHY\",\"inline\":false},"
[ -n "$RESTARTING" ] && FIELDS="${FIELDS}{\"name\":\"Restarting\",\"value\":\"$RESTARTING\",\"inline\":false},"

curl -s -X POST "$WEBHOOK" -H "Content-Type: application/json" -d "{
  \"embeds\": [{
    \"title\": \"$TITLE\",
    \"color\": $COLOR,
    \"fields\": [${FIELDS%,}],
    \"timestamp\": \"$(date -u +%Y-%m-%dT%H:%M:%SZ)\"
  }]
}"
